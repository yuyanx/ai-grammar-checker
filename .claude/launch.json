{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "esbuild-watch",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "esbuild",
        "src/background/service-worker.ts",
        "src/content/index.ts",
        "src/content/page-script.ts",
        "src/popup/popup.ts",
        "src/options/options.ts",
        "--bundle",
        "--outdir=dist",
        "--format=iife",
        "--target=es2020",
        "--watch"
      ],
      "port": 8080
    },
    {
      "name": "tsc-watch",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsc", "--watch", "--noEmit"],
      "port": 8081
    }
  ]
}
